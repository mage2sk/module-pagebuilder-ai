                <div class="panth-ai-row" style="align-items:flex-start;">
                    <label for="panth-ai-ids" style="margin-top:6px;"><?= $block->escapeHtml(__('Entity IDs')) ?></label>
                    <textarea name="ids_raw" id="panth-ai-ids" rows="4" placeholder="<?= $block->escapeHtmlAttr(__('e.g. 1, 2, 3 or one ID per line')) ?>"></textarea>
                </div>

                <div class="panth-ai-row">
                    <span style="min-width:110px;"></span>
                    <button type="submit" class="action-primary" id="panth-ai-batch-submit">
                        <?= $block->escapeHtml(__('Queue Generation Job')) ?>
                    </button>
                    <span class="panth-ai-muted">
                        <?= $block->escapeHtml(__('Max 500 IDs per job. Leave empty to abort.')) ?>
                    </span>
                </div>
            </form>

            <script>
                (function () {
                    var form = document.getElementById('panth-ai-batch-form');
                    if (!form) return;
                    form.addEventListener('submit', function (e) {
                        var ta = document.getElementById('panth-ai-ids');
                        var raw = (ta.value || '').trim();
                        if (!raw) {
                            e.preventDefault();
                            alert('<?= $block->escapeJs(__('Please provide at least one entity ID.')) ?>');
                            return;
                        }
                        var ids = raw.split(/[\s,;]+/).map(function (x) { return parseInt(x, 10); })
                                     .filter(function (n) { return n > 0; }).slice(0, 500);
                        if (!ids.length) {
                            e.preventDefault();
                            alert('<?= $block->escapeJs(__('No valid numeric IDs found.')) ?>');
                            return;
                        }
                        // Strip existing ids[] inputs, then append one hidden input per ID.
                        Array.prototype.slice.call(form.querySelectorAll('input[name="ids[]"]')).forEach(function (n) { n.remove(); });
                        ids.forEach(function (id) {
                            var inp = document.createElement('input');
                            inp.type = 'hidden';
                            inp.name = 'ids[]';
                            inp.value = String(id);
                            form.appendChild(inp);
                        });
                    });
                })();
            </script>
        </div>

        <!-- Scheduling / cron panel ------------------------------------- -->
        <div class="panth-ai-card">
