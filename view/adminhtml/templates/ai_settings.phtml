    'cron_run' =&gt; true,
    'max_messages' =&gt; 500,
    'consumers' =&gt; [
        'panth_pagebuilderai.generate_meta.consumer',
    ],
],</pre>

            <p style="margin: 12px 0 4px;"><strong><?= $block->escapeHtml(__('Manual (one-off or dev)')) ?></strong></p>
            <pre class="panth-ai-cmd">bin/magento queue:consumers:start panth_pagebuilderai.generate_meta.consumer --max-messages=500</pre>

            <p style="margin: 12px 0 4px;"><strong><?= $block->escapeHtml(__('Scheduled / at a specific time')) ?></strong></p>
            <p class="panth-ai-muted" style="margin:0;">
