<?xml version="1.0" encoding="UTF-8"?>
<listing xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="urn:magento:module:Magento_Ui:etc/ui_configuration.xsd">
    <argument name="data" xsi:type="array">
        <item name="js_config" xsi:type="array">
            <item name="provider" xsi:type="string">panth_pagebuilderai_ai_prompt_listing.panth_pagebuilderai_ai_prompt_listing_data_source</item>
        </item>
    </argument>
    <settings>
        <spinner>panth_pagebuilderai_ai_prompt_listing_columns</spinner>
        <deps>
            <dep>panth_pagebuilderai_ai_prompt_listing.panth_pagebuilderai_ai_prompt_listing_data_source</dep>
        </deps>
        <buttons>
            <button name="add">
                <url path="*/*/new"/>
                <class>primary</class>
                <label translate="true">Add New AI Prompt</label>
            </button>
        </buttons>
    </settings>
    <dataSource name="panth_pagebuilderai_ai_prompt_listing_data_source" component="Magento_Ui/js/grid/provider">
        <settings>
            <storageConfig>
                <param name="indexField" xsi:type="string">prompt_id</param>
            </storageConfig>
            <updateUrl path="mui/index/render"/>
        </settings>
        <dataProvider class="Magento\Framework\View\Element\UiComponent\DataProvider\DataProvider" name="panth_pagebuilderai_ai_prompt_listing_data_source">
            <settings>
                <requestFieldName>id</requestFieldName>
                <primaryFieldName>prompt_id</primaryFieldName>
            </settings>
        </dataProvider>
    </dataSource>
    <listingToolbar name="listing_top">
        <bookmark name="bookmarks"/>
        <columnsControls name="columns_controls"/>
        <filters name="listing_filters"/>
        <paging name="listing_paging"/>
    </listingToolbar>
    <columns name="panth_pagebuilderai_ai_prompt_listing_columns">
        <selectionsColumn name="ids">
            <settings>
                <indexField>prompt_id</indexField>
            </settings>
        </selectionsColumn>
        <column name="prompt_id">
            <settings>
                <label translate="true">ID</label>
                <sorting>asc</sorting>
            </settings>
        </column>
        <column name="name">
            <settings>
                <label translate="true">Name</label>
                <filter>text</filter>
            </settings>
        </column>
        <column name="entity_type">
            <settings>
                <label translate="true">Entity Type</label>
                <filter>text</filter>
            </settings>
        </column>
        <column name="is_default" component="Magento_Ui/js/grid/columns/select">
            <settings>
                <label translate="true">Default</label>
                <dataType>select</dataType>
                <options class="Magento\Config\Model\Config\Source\Yesno"/>
            </settings>
        </column>
        <column name="is_active" component="Magento_Ui/js/grid/columns/select">
            <settings>
                <label translate="true">Active</label>
                <dataType>select</dataType>
                <options class="Magento\Config\Model\Config\Source\Yesno"/>
            </settings>
        </column>
        <column name="sort_order">
            <settings>
                <label translate="true">Sort Order</label>
                <dataType>number</dataType>
            </settings>
        </column>
        <actionsColumn name="actions" class="Panth\PageBuilderAi\Ui\Component\Listing\Column\AiPromptActions">
            <settings>
                <indexField>prompt_id</indexField>
            </settings>
        </actionsColumn>
    </columns>
</listing>
