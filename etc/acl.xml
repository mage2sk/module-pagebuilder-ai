<?xml version="1.0"?>
<config xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="urn:magento:framework:Acl/etc/acl.xsd">
    <acl>
        <resources>
            <resource id="Magento_Backend::admin">
                <!--
                    System-config section resource.
                    This is the ONLY location where Panth_PageBuilderAi::config may be declared;
                    it must never also appear under Panth_Core::panth_extensions (duplicate resource ids
                    fail the uniqueResourceId XSD check).
                -->
                <resource id="Magento_Backend::stores">
                    <resource id="Magento_Backend::stores_settings">
                        <resource id="Magento_Config::config">
                            <resource id="Panth_PageBuilderAi::config" title="Panth PageBuilder AI" sortOrder="80"/>
                        </resource>
                    </resource>
                </resource>

                <!--
                    Admin routes / menu resources.
                    Parent ai_manage groups every AI-related sub-resource so an admin role can be
                    granted "AI" access in one checkbox.
                -->
                <resource id="Panth_PageBuilderAi::ai_manage" title="PageBuilder AI" sortOrder="90">
                    <resource id="Panth_PageBuilderAi::ai_generate" title="Generate with AI" sortOrder="10"/>
                    <resource id="Panth_PageBuilderAi::ai_settings" title="AI Dashboard" sortOrder="15"/>
                    <resource id="Panth_PageBuilderAi::ai_jobs" title="AI Generation Jobs" sortOrder="20"/>
                    <resource id="Panth_PageBuilderAi::ai_prompts" title="AI Prompts" sortOrder="30"/>
                    <resource id="Panth_PageBuilderAi::ai_knowledge" title="AI Knowledge Base" sortOrder="40"/>
                    <resource id="Panth_PageBuilderAi::ai_request_logs" title="AI Request Logs" sortOrder="50"/>
                </resource>

                <!-- Legacy standalone resource — still used by Controller\Adminhtml\Generate\Index. -->
                <resource id="Panth_PageBuilderAi::generate" title="PageBuilder AI Generate" sortOrder="95"/>
            </resource>
        </resources>
    </acl>
</config>
